<div class="vh-center">
  <div class="container--sm">
    <div class="text-center mb-4">
      <h1 class="text-heading">🔴 Store</h1>
      <p class="text-lead">Sign in to your account</p>
    </div>

    <div class="card">
      <div class="card-body">
        <%= form_with model: resource, as: resource_name, url: session_path(resource_name) do |form| %>
          <div class="form-group">
            <%= form.label :email, "Email", class: "form-label" %>
            <%= form.email_field :email,
                                 required: true,
                                 autofocus: true,
                                 autocomplete: "email",
                                 placeholder: "your@email.com",
                                 value: params[:email],
                                 class: "form-control" %>
          </div>

          <div class="form-group">
            <%= form.label :password, "Password", class: "form-label" %>
            <%= form.password_field :password,
                                    required: true,
                                    autocomplete: "current-password",
                                    placeholder: "Enter your password",
                                    maxlength: 72,
                                    class: "form-control" %>
          </div>

          <div class="form-group mb-0">
            <%= form.submit "Sign in", class: "btn btn--primary btn--block btn--lg" %>
          </div>
        <% end %>
        <div class="actions-column">
          <div class="flex gap-2">
            <%= link_to "✏️ Register", new_user_registration_path, class: "btn btn--outline-dark btn--block" %>
          </div>
      </div>
    </div>
  </div>
</div>
