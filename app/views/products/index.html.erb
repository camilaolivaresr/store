<div class="text-center mb-4">
  <h1 class="text-title">Products</h1>
</div>

<div class="products-grid p-2">
  <% @products.each do |product| %>
    <div class="card">
      <div class="card-body">
        <h3 class="card-title"><%= product.name %></h3>
      </div>
    </div>
  <% end %>
</div>


<%= debug @products %>
<%= @products %>

